## UUID-Based Document IDs

### Why UUIDs for Offline-First?

```typescript
// ✅ GOOD: Client-generated UUID
import { v4 as uuid } from 'uuid';

const userId = uuid(); // Generated offline
await setDoc(doc(db, 'users', userId), {
  name: 'John Doe',
  email: 'john@example.com',
  created_at: serverTimestamp(),
});

// ❌ BAD: Server-generated ID
const docRef = await addDoc(collection(db, 'users'), {
  name: 'John Doe',
  // Problem: Requires online connection to get ID
});
```

### UUID Pattern

```typescript
// src/infrastructure/firebase/document-helpers.ts
import { v4 as uuid } from 'uuid';
import { doc, setDoc, Timestamp } from 'firebase/firestore';

export async function createDocument<T>(
  collectionPath: string,
  data: T,
  customId?: string
): Promise<string> {
  const docId = customId || uuid();
  
  await setDoc(doc(db, collectionPath, docId), {
    ...data,
    created_at: Timestamp.now(),
    updated_at: Timestamp.now(),
  });
  
  return docId;
}
```

