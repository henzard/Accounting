## Logging Best Practices (Public Repo)

### NEVER Log Sensitive Data

```typescript
// ❌ BAD: Logging sensitive info
logger.info('User login', { 
  email: user.email,           // Personal info
  password: password,          // NEVER log passwords
  token: authToken,            // Sensitive
  accountNumber: user.account, // Personal info
});

// ✅ GOOD: Safe logging
logger.info('User login', { 
  userId: user.id,             // Non-sensitive ID
  timestamp: Date.now(),
  success: true,
});

// ✅ GOOD: Redacted logging
logger.debug('Request', {
  email: maskEmail(user.email), // user@example.com → u***@example.com
  accountNumber: maskAccount(account), // 1234567890 → ******7890
});
```

### Helper Functions for Safe Logging

```typescript
// src/shared/utils/masking.ts

export function maskEmail(email: string): string {
  const [local, domain] = email.split('@');
  return `${local[0]}***@${domain}`;
}

export function maskAccountNumber(account: string): string {
  if (account.length <= 4) return '****';
  return '******' + account.slice(-4);
}

export function maskPhoneNumber(phone: string): string {
  // Mask all digits except the last 4, preserving formatting
  const digits = phone.match(/\d/g);
  if (!digits || digits.length <= 4) return phone;
  
  let maskedCount = 0;
  const digitsToMask = digits.length - 4;
  
  return phone.replace(/\d/g, () => {
    maskedCount++;
    return maskedCount <= digitsToMask ? '*' : digits[maskedCount - 1];
  });
}

export function redactSensitiveData(obj: any): any {
  const redacted = { ...obj };
  const sensitiveKeys = ['password', 'token', 'secret', 'key', 'credential'];
  
  for (const key in redacted) {
    if (sensitiveKeys.some(k => key.toLowerCase().includes(k))) {
      redacted[key] = '[REDACTED]';
    }
  }
  
  return redacted;
}
```

