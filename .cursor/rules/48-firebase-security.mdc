## Migration from SQLite

If migrating from SQLite to Firestore:

### Data Migration Script

```typescript
// scripts/migrate-to-firestore.ts
import { readFromSQLite } from './sqlite-export';
import { writeBatch } from 'firebase/firestore';

async function migrateData() {
  const sqliteData = await readFromSQLite();
  const batch = writeBatch(db);
  
  // Batch write in chunks of 500 (Firestore limit)
  let count = 0;
  
  for (const user of sqliteData.users) {
    const docRef = doc(db, 'users', user.id);
    batch.set(docRef, user);
    
    count++;
    if (count % 500 === 0) {
      await batch.commit();
      console.log(`Migrated ${count} users`);
    }
  }
  
  await batch.commit();
  console.log('Migration complete');
}
```

