## Common Patterns

### Pattern 1: Error Handling

```typescript
try {
  await saveTransaction(transaction);
  showAlert('Success', 'Transaction saved');
  router.back();
} catch (error) {
  console.error('Failed to save:', error);
  showAlert('Error', error.message || 'Failed to save transaction');
}
```

### Pattern 2: Validation

```typescript
const handleSave = async () => {
  if (!name.trim()) {
    showAlert('Validation Error', 'Please enter a name');
    return;
  }

  if (amount <= 0) {
    showAlert('Validation Error', 'Amount must be greater than zero');
    return;
  }

  // Proceed with save...
};
```

### Pattern 3: Delete Confirmation

```typescript
const handleDelete = async (id: string) => {
  showConfirm(
    'Delete Item?',
    'This action cannot be undone.',
    async () => {
      try {
        await deleteItem(id);
        showAlert('Success', 'Item deleted');
        loadItems();
      } catch (error) {
        showAlert('Error', 'Failed to delete item');
      }
    }
  );
};
```

### Pattern 4: Sign Out

```typescript
const handleSignOut = async () => {
  showConfirm(
    'Sign Out?',
    'Are you sure you want to sign out?',
    async () => {
      try {
        await signOut();
        router.replace('/login');
      } catch (error) {
        showAlert('Error', 'Failed to sign out');
      }
    }
  );
};
```

