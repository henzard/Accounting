## Component Composition Example

### Complete Form with Searchable Selects
```typescript
// src/presentation/screens/transaction-form.screen.tsx
export const TransactionFormScreen: React.FC = () => {
  const { control, handleSubmit } = useForm<TransactionFormData>();

  return (
    <ScrollView>
      {/* Category - Searchable with Quick Add */}
      <Controller
        control={control}
        name="category"
        render={({ field }) => (
          <SearchableSelect
            label="Category"
            items={categoryList}
            value={field.value}
            onValueChange={field.onChange}
            onQuickAdd={handleQuickAddCategory}
            quickAddLabel="Add New Category"
          />
        )}
      />

      {/* Tags - Multi-select with Quick Add */}
      <Controller
        control={control}
        name="tags"
        render={({ field }) => (
          <MultiSelect
            label="Tags"
            items={tagsList}
            value={field.value}
            onChange={field.onChange}
            onQuickAdd={handleQuickAddTag}
            max={5}
          />
        )}
      />

      {/* Account - Grouped with Quick Add */}
      <Controller
        control={control}
        name="account"
        render={({ field }) => (
          <GroupedSelect
            label="Account"
            items={accountsList}
            value={field.value}
            onValueChange={field.onChange}
            onQuickAdd={handleQuickAddAccount}
          />
        )}
      />

      <Button title="Save" onPress={handleSubmit(onSubmit)} />
    </ScrollView>
  );
};
```

