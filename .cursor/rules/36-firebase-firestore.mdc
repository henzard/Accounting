## Offline Persistence

### Enable Offline Persistence

```typescript
// src/infrastructure/firebase/offline-setup.ts
import { initializeFirestore, persistentLocalCache } from 'firebase/firestore';

// Web
import { enableIndexedDbPersistence } from 'firebase/firestore';

export async function setupOfflineFirst() {
  try {
    await enableIndexedDbPersistence(db);
    console.log('Offline persistence enabled');
  } catch (err: any) {
    if (err.code === 'failed-precondition') {
      // Multiple tabs open, persistence only enabled in one tab
      console.warn('Offline persistence failed: Multiple tabs open');
    } else if (err.code === 'unimplemented') {
      // Browser doesn't support persistence
      console.warn('Offline persistence not available in this browser');
    }
  }
}

// React Native
import { initializeFirestore } from '@react-native-firebase/firestore';

export function setupOfflineFirstRN() {
  // Offline persistence is enabled by default in React Native
  // Configure cache size if needed
  firestore().settings({
    cacheSizeBytes: 100 * 1024 * 1024, // 100 MB
  });
}
```

### How Offline Persistence Works

```typescript
/*
 * Offline Flow:
 * 
 * 1. User writes data while offline
 *    → Write goes to local cache immediately
 *    → Write added to pending queue
 *    → UI updates instantly (optimistic)
 * 
 * 2. User goes online
 *    → SDK automatically uploads pending writes
 *    → Server acknowledges
 *    → Local cache syncs with server
 * 
 * 3. Other devices
 *    → Receive real-time updates
 *    → Local cache updates
 *    → UI updates via listeners
 */
```

