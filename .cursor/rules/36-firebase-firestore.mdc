## Realtime Listeners

### Basic Listener

```typescript
// src/presentation/viewmodels/user-list.viewmodel.ts
import { onSnapshot, collection, query, where } from 'firebase/firestore';

export class UserListViewModel {
  private unsubscribe?: () => void;

  startListening(householdId: string) {
    const q = query(
      collection(db, 'users'),
      where('household_ids', 'array-contains', householdId)
    );

    this.unsubscribe = onSnapshot(
      q,
      (snapshot) => {
        const users = snapshot.docs.map(doc => ({
          id: doc.id,
          ...doc.data(),
        }));
        
        // Update UI
        this.updateUsers(users);
      },
      (error) => {
        console.error('Listener error:', error);
        this.handleError(error);
      }
    );
  }

  stopListening() {
    if (this.unsubscribe) {
      this.unsubscribe();
    }
  }
}
```

### Detecting Pending Writes

```typescript
// Show "syncing..." indicator
import { onSnapshot } from 'firebase/firestore';

onSnapshot(docRef, (doc) => {
  const hasPendingWrites = doc.metadata.hasPendingWrites;
  
  if (hasPendingWrites) {
    console.log('Document has local changes not yet synced');
    // Show "Syncing..." indicator
  } else {
    console.log('Document is in sync with server');
    // Hide "Syncing..." indicator
  }
});
```

