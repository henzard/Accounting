## Best Practices

### 1. Document Size Limits

```typescript
// ❌ BAD: Large arrays in document
interface TransactionBad {
  id: string;
  allocations: Allocation[]; // Could grow unbounded
}

// ✅ GOOD: Use subcollection
transactions/{txId}/allocations/{allocationId}
```

### 2. Denormalization for Performance

```typescript
// ✅ Denormalize frequently accessed data
interface Transaction {
  id: string;
  user_id: string;
  user_name: string; // Denormalized for display
  user_email: string; // Denormalized for display
  amount: number;
}

// Keep source of truth
users/{userId}
```

### 3. Timestamps

```typescript
// ✅ GOOD: Use server timestamps
import { serverTimestamp } from 'firebase/firestore';

await setDoc(doc(db, 'users', userId), {
  name: 'John',
  created_at: serverTimestamp(), // Set by server
});

// ❌ BAD: Client timestamps (can be wrong)
await setDoc(doc(db, 'users', userId), {
  name: 'John',
  created_at: new Date(), // Client time might be wrong
});
```

### 4. Error Handling

```typescript
// src/infrastructure/firebase/error-handler.ts
import { FirebaseError } from 'firebase/app';

export function handleFirebaseError(error: unknown): Error {
  if (error instanceof FirebaseError) {
    switch (error.code) {
      case 'permission-denied':
        return new Error('You do not have permission to access this data');
      case 'not-found':
        return new Error('Document not found');
      case 'unavailable':
        return new Error('Service temporarily unavailable. Please try again.');
      default:
        return new Error(`Firebase error: ${error.message}`);
    }
  }
  
  return error instanceof Error ? error : new Error('Unknown error');
}
```

### 5. Cleanup on Unmount

```typescript
// src/presentation/hooks/use-firestore-query.ts
import { useEffect, useState } from 'react';
import { onSnapshot } from 'firebase/firestore';

export function useFirestoreQuery<T>(queryRef: Query) {
  const [data, setData] = useState<T[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<Error | null>(null);

  useEffect(() => {
    const unsubscribe = onSnapshot(
      queryRef,
      (snapshot) => {
        const items = snapshot.docs.map(doc => ({
          id: doc.id,
          ...doc.data(),
        } as T));
        setData(items);
        setLoading(false);
      },
      (err) => {
        setError(err);
        setLoading(false);
      }
    );

    // Cleanup listener on unmount
    return () => unsubscribe();
  }, [queryRef]);

  return { data, loading, error };
}
```

