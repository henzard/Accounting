## Repository Pattern with Firestore

### Repository Implementation

```typescript
// src/data/repositories/user-repository.firestore.ts
import {
  collection,
  doc,
  getDoc,
  getDocs,
  setDoc,
  updateDoc,
  deleteDoc,
  query,
  where,
  orderBy,
  limit,
  Timestamp,
} from 'firebase/firestore';
import { IUserRepository } from '@/domain/repositories/i-user-repository';
import { User } from '@/domain/entities/user';
import { db } from '@/infrastructure/firebase/config';

export class FirestoreUserRepository implements IUserRepository {
  private readonly collectionName = 'users';

  async findById(id: string): Promise<User | null> {
    const docRef = doc(db, this.collectionName, id);
    const docSnap = await getDoc(docRef);
    
    if (!docSnap.exists()) {
      return null;
    }
    
    return this.mapToEntity(docSnap.id, docSnap.data());
  }

  async save(user: User): Promise<void> {
    const docRef = doc(db, this.collectionName, user.id);
    const data = this.mapToDocument(user);
    
    await setDoc(docRef, data, { merge: true });
  }

  async findByEmail(email: string): Promise<User | null> {
    const q = query(
      collection(db, this.collectionName),
      where('email', '==', email),
      limit(1)
    );
    
    const querySnapshot = await getDocs(q);
    
    if (querySnapshot.empty) {
      return null;
    }
    
    const doc = querySnapshot.docs[0];
    return this.mapToEntity(doc.id, doc.data());
  }

  private mapToEntity(id: string, data: any): User {
    return new User({
      id,
      email: data.email,
      name: data.name,
      createdAt: data.created_at?.toDate() || new Date(),
      updatedAt: data.updated_at?.toDate() || new Date(),
    });
  }

  private mapToDocument(user: User): any {
    return {
      email: user.email,
      name: user.name,
      created_at: Timestamp.fromDate(user.createdAt),
      updated_at: Timestamp.fromDate(user.updatedAt),
    };
  }
}
```

