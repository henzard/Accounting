## Conflict Resolution

### Understanding "Last Write Wins"

```typescript
/*
 * Firestore Conflict Resolution:
 * 
 * Device A (offline): Updates transaction amount to $100
 * Device B (offline): Updates same transaction amount to $150
 * Both go online:
 *   → Whichever write reaches server LAST wins
 *   → The other update is lost
 * 
 * Solutions:
 * 1. Append-only pattern (preferred for accounting)
 * 2. Version fields with manual conflict detection
 * 3. Use subcollections for history
 */
```

### Append-Only Pattern

```typescript
// ✅ GOOD: Append-only for financial data
interface Transaction {
  id: string;
  original_amount: number;
  corrections: CorrectionEntry[];
  effective_amount: number; // Computed
}

// Never edit in place, add corrections
async function correctTransaction(txId: string, newAmount: number) {
  const correction = {
    id: uuid(),
    amount: newAmount,
    corrected_at: Timestamp.now(),
    corrected_by: currentUserId,
  };
  
  await updateDoc(doc(db, 'transactions', txId), {
    corrections: arrayUnion(correction),
  });
}
```

### Version-Based Detection

```typescript
// Add version field to detect conflicts
interface VersionedDocument {
  id: string;
  data: any;
  version: number;
  updated_at: Timestamp;
}

async function updateWithVersionCheck(docId: string, newData: any, expectedVersion: number) {
  await runTransaction(db, async (transaction) => {
    const docRef = doc(db, 'documents', docId);
    const docSnap = await transaction.get(docRef);
    
    const currentVersion = docSnap.data()?.version || 0;
    
    if (currentVersion !== expectedVersion) {
      throw new Error('Version conflict - document was modified');
    }
    
    transaction.update(docRef, {
      ...newData,
      version: currentVersion + 1,
      updated_at: Timestamp.now(),
    });
  });
}
```

