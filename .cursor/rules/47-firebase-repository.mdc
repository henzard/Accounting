## Pagination

### Cursor-Based Pagination

```typescript
// src/data/repositories/transaction-repository.firestore.ts
import { query, orderBy, limit, startAfter, getDocs } from 'firebase/firestore';

export class TransactionRepository {
  async getTransactions(
    pageSize: number = 20,
    lastDoc?: any
  ): Promise<{ items: Transaction[]; lastDoc: any }> {
    let q = query(
      collection(db, 'transactions'),
      orderBy('date', 'desc'),
      limit(pageSize)
    );
    
    if (lastDoc) {
      q = query(q, startAfter(lastDoc));
    }
    
    const snapshot = await getDocs(q);
    
    // Check if we have any results
    if (snapshot.docs.length === 0) {
      return { items: [], lastDoc: null };
    }
    
    const items = snapshot.docs.map(doc => this.mapToEntity(doc));
    const lastVisible = snapshot.docs[snapshot.docs.length - 1];
    
    return { items, lastDoc: lastVisible };
  }
}
```

