{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@/domain/*": ["./domain/*"],
      "@/data/*": ["./data/*"],
      "@/presentation/*": ["./presentation/*"],
      "@/infrastructure/*": ["./infrastructure/*"],
      "@/shared/*": ["./shared/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
